# BuildID
# ───────────────────────────────────────────
# Signaling server
PORT=8080
PUBLIC_HOST=http://localhost:8080

# Pairing / auth
SESSION_SECRET=change-me-to-a-long-random-string
LINK_CODE_TTL_SECONDS=600

# WebRTC ICE servers (JSON array). Add a TURN server for production NAT traversal.
ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
# Example with TURN:
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]

# Optional TLS (recommended for production). Leave blank to serve plain HTTP.
TLS_CERT=
TLS_KEY=
